# 個人データ・アーカイブは公開しない
wbs-archive-*.json

# 内部開発ルール（dev_kit由来）は非公開
.claude/
*Zone.Identifier

# Python バイトコード（e2eテストの実行で生成・コミット不要）
__pycache__/
*.pyc

# テストハーネスの仮想環境（uv 管理・各自で uv sync して生成）。pyproject.toml と uv.lock は追跡
.venv/
.python-version

# 実運用データはローカルのみ（公開サンプルは wbs.json）
wbs-local*.json
# 自分の実データ（慣用名）。サンプルは wbs_sample.json / 開発計画は wbs_roadmap.json
wbs.json
